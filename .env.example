# Photo Organizer Configuration
# Copy to .env and adjust for your setup

# ── Required ──────────────────────────────────────────────────

# Path to photo/video collection
MEDIA_ROOT=/path/to/your/photos

# Ollama LLM server (your GPU PC)
OLLAMA_URL=http://YOUR_OLLAMA_HOST:11434

# ── Optional (defaults shown) ────────────────────────────────

# SQLite database location
DB_PATH=~/photo_audit.db

# Vision model for photo analysis
VISION_MODEL=qwen3-vl:32b

# Directories to skip during scan
SKIP_DIRS=$RECYCLE.BIN,System Volume Information,.qsyncclient

# GPS propagation default time window (hours)
GPS_WINDOW_HOURS=4

# Batch analysis default size
BATCH_SIZE=10
